<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or "nano};{ranch" }}</title>
    <meta name="description" content="{{ description or 'Scalable stewardship for a range of rewilding.' }}">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ ogTitle or title or 'nano};{ranch' }}">
    <meta property="og:description" content="{{ ogDescription or description or 'Scalable stewardship for a range of rewilding.' }}">
    <meta property="og:url" content="{{ ogUrl or 'https://nanoranch.org/' }}">
    <meta property="og:type" content="website">
    <meta property="og:image" content="/nanoranch-opengraph.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,200;0,300;0,400;0,600;1,500&family=Lexend:wght@300;400&family=Outfit:wght@300;400&display=swap" rel="stylesheet">

    <!-- Styles -->
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>

    {% include "nav.njk" %}

    {{ content | safe }}

    {% include "footer.njk" %}

    <script src="/js/main.js" defer></script>
</body>
</html>
